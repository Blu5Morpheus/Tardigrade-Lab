# Copy this to secrets.toml for local dev. NEVER commit secrets.toml.
# In production, all of these are set as Render environment variables
# (see render.yaml for the names).

[admin]
# bcrypt hash of the admin password. Generate with:
#   python -c "import bcrypt; print(bcrypt.hashpw(b'YOUR_PASSWORD', bcrypt.gensalt()).decode())"
password_hash = "$2b$12$REPLACE_ME_WITH_BCRYPT_HASH"
username = "raven"
# Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
session_secret = "REPLACE_ME_WITH_64_CHAR_HEX"

[supabase]
url = "https://YOUR_PROJECT.supabase.co"
anon_key = "eyJ..."
service_role_key = "eyJ..."  # admin operations only

[github]
# fine-grained PAT scoped to the tardigrade-site repo, contents: read+write
token = "github_pat_..."
repo = "raven-roberts/tardigrade-site"
default_branch = "main"
committer_name = "Tardigrade Admin"
committer_email = "ravenroberts@tardigradeinnovation.com"

[formspree]
api_key = ""        # API key for read access to submissions (account → API)
form_id = "mkoyrezo"

[plausible]
# optional — only if Raven sets up Plausible analytics
site_id = "portfolio-lab-v05x.onrender.com"
api_key = ""

[stripe]
# only filled in post-launch
secret_key = ""

[groq]
api_key = "gsk_..."
model = "llama-3.3-70b-versatile"

[render]
# Render deploy hook for the Astro site, used by "Trigger rebuild" button
deploy_hook_url = ""
